{
    "name": "moowoodle",
    "displayName": "Moowoodle",
    "version": "3.4.0",
    "description": "Moowoodle",
    "license": "GPL-2.0-or-later",
    "mainPluginFile": "moowoodle.php",
    "engines": {
        "node": "^24.0.2"
    },
    "scripts": {
        "build": "pnpm run build:project",
        "build:project": "pnpm --if-present \"/^build:project:.*$/\"",
        "build:project:bundle": "wireit",
        "build:release": "pnpm run readme && pnpm run version && pnpm run build:project && pnpm run makepot && pnpm run makejson && pnpm run release",
        "build:zip": "pnpm run build:release",
        "watch": "pnpm run watch:build",
        "watch:build": "pnpm --if-present run \"/^watch:build:project:.*$/\"",
        "watch:build:project:bundle": "wireit",
        "lint:js": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs",
        "fix:js": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs --fix",
        "lint:css": "stylelint \"**/*.{css,scss}\"",
        "fix:css": "stylelint \"**/*.{css,scss}\" --fix",
        "lint:php": "composer run-script phpcs",
        "fix:php": "composer run-script phpfix",
        "test": "pnpm test:php",
        "test:php": "./vendor/bin/phpunit -c ./phpunit.xml.dist",
        "env:create": "pnpm wp-env start && pnpm run env:start:database",
        "env:start": "pnpm wp-env start && pnpm run env:start:database",
        "env:start:database": "node ../../tools/scripts/docker-compose.mjs && docker compose up -d",
        "env:dev": "pnpm wp-env start --update && pnpm run env:start:database",
        "env:stop": "pnpm wp-env stop && docker compose down",
        "env:restart": "pnpm wp-env restart",
        "env:clean": "pnpm wp-env clean",
        "env:destroy": "pnpm wp-env destroy && rimraf docker-compose.yml",
        "readme": "wp-readme-to-md",
        "composer": "composer dump-autoload && composer update",
        "clean": "node ../../tools/scripts/clean.mjs moowoodle",
        "minify": "node ../../tools/scripts/minify.mjs moowoodle",
        "move": "node ../../tools/scripts/move-files.mjs moowoodle",
        "release": "node ../../tools/scripts/release.mjs moowoodle",
        "version": "node ../../tools/scripts/version-replace.mjs moowoodle",
        "textdomain": "node ../../tools/scripts/update-textdomain.mjs moowoodle",
        "makepot": "pnpm exec wp i18n make-pot --domain='moowoodle' --include='assets/js,public/js,classes,templates,config.php,moowoodle.php' . languages/moowoodle.pot",
        "makejson": "pnpm exec wp i18n make-json languages --pretty-print --no-purge",
        "postinstall": "composer install"
    },
    "wireit": {
        "build:project:bundle": {
            "command": "wp-scripts build --progress && pnpm run minify && pnpm run move && pnpm run clean",
            "files": [
                "src/**/*.{js,jsx,ts,tsx,scss}",
                "modules/**/*.{js,jsx,ts,tsx,scss}",
                "public/**/*",
                "webpack.config.js",
                "tsconfig.json"
            ],
            "output": [
                "assets/**"
            ],
            "clean": true
        },
        "watch:build:project:bundle": {
            "command": "wp-scripts start",
            "files": [
                "src/**/*.{js,jsx,ts,tsx,scss}",
                "modules/**/*.{js,jsx,ts,tsx,scss}",
                "public/**/*",
                "webpack.config.js",
                "tsconfig.json"
            ],
            "service": true
        }
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.0",
        "@mui/material": "^7.1.0",
        "@tanstack/react-table": "^8.21.3",
        "@tinymce/tinymce-react": "^5.1.0",
        "@wordpress/data": "wp-6.6",
        "@wordpress/element": "wp-6.6",
        "@wordpress/hooks": "^4.45.0",
        "@wordpress/i18n": "wp-6.6",
        "@wordpress/react-i18n": "wp-6.6",
        "axios": "^1.16.1",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "react-router-dom": "^7.6.0",
        "react-select": "^5.10.1",
        "zyra": "workspace:*"
    },
    "devDependencies": {
        "@wordpress/env": "10.23.x",
        "css-loader": "^7.1.4",
        "style-loader": "^4.0.0",
        "wireit": "^0.14.12"
    }
}